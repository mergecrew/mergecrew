{
  "name": "@mergecrew/db",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "default": "./dist/client.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "generate": "prisma generate --schema prisma/schema.prisma",
    "migrate": "prisma migrate deploy --schema prisma/schema.prisma",
    "migrate:dev": "prisma migrate dev --schema prisma/schema.prisma",
    "reset": "prisma migrate reset --schema prisma/schema.prisma --force",
    "seed": "tsx src/seed.ts",
    "studio": "prisma studio --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@mergecrew/domain": "workspace:*",
    "@types/node": "^25.9.1",
    "dotenv": "^17.4.2",
    "prisma": "^7.8.0",
    "tsx": "^4.22.3",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1",
    "yaml": "^2.9.0"
  },
  "prisma": {
    "seed": "tsx src/seed.ts"
  }
}
