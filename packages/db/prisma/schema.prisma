// Mergecrew database schema. See docs/02-architecture/09-data-model.md.
// pgvector is used for memory embeddings via raw SQL migration since
// Prisma's vector support is preview-flagged.

// Multi-target binaries so a build container that compiles on one libssl
// can run inside another. `native` covers `pnpm dev`; the linux-* targets
// cover the Debian-based Dockerfiles (debian-openssl-3.0.x is bookworm)
// and arm64 macs that run linux/arm64 images locally.
generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "linux-arm64-openssl-3.0.x", "linux-arm64-openssl-1.1.x", "debian-openssl-3.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DATABASE_MIGRATE_URL")
  extensions = [uuidOssp(map: "uuid-ossp"), pgcrypto, vector]
}

// ─────────────────────────────────────────────────────────────────────────────
// Identity & tenancy
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id                   String                @id @default(uuid()) @db.Uuid
  email                String                @unique
  name                 String?
  avatarUrl            String?               @map("avatar_url")
  defaultOrgId         String?               @map("default_org_id") @db.Uuid
  /// Confirmed TOTP secret (envelope-encrypted via CryptoService). NULL when
  /// the user hasn't completed MFA enrollment.
  mfaSecretCiphertext  Bytes?                @map("mfa_secret_ciphertext")
  /// Pending (unconfirmed) TOTP secret produced by /mfa/setup. Cleared on
  /// successful /mfa/verify or on a fresh setup call.
  mfaPendingCiphertext Bytes?                @map("mfa_pending_ciphertext")
  /// Set once /mfa/verify accepts the first valid TOTP. NULL means the user
  /// is not enrolled.
  mfaEnrolledAt        DateTime?             @map("mfa_enrolled_at") @db.Timestamptz(6)
  /// One row per remaining single-use recovery code (sha256 hashed). On
  /// consumption the matching row is deleted, not flipped — keeps the table
  /// honest about how many codes remain.
  mfaRecoveryCodes     UserMfaRecoveryCode[]
  createdAt            DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime              @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  memberships       Membership[]
  decisions         Decision[]
  intentItems       IntentInboxItem[]
  approvals         ApprovalRequest[]  @relation("ApprovalResolvedBy")
  changesetComments ChangesetComment[]

  @@map("users")
}

model Organization {
  id                       String    @id @default(uuid()) @db.Uuid
  slug                     String    @unique
  name                     String
  timezone                 String    @default("UTC")
  workingHoursStart        String    @default("09:00") @map("working_hours_start")
  workingHoursEnd          String    @default("18:00") @map("working_hours_end")
  defaultLlmProfileId      String?   @map("default_llm_profile_id") @db.Uuid
  defaultGatePolicyId      String?   @map("default_gate_policy_id") @db.Uuid
  /// Hard daily spend cap across all LLM providers. NULL = unlimited.
  dailyBudgetUsd           Decimal?  @map("daily_budget_usd") @db.Decimal(10, 2)
  /// Hard monthly spend cap across all LLM providers (#282). NULL = unlimited.
  /// Enforced calendar-month (UTC) at agent-step pre-flight: a run that would
  /// push month-to-date past the cap is rejected with reason `cap_exceeded`
  /// rather than truncated mid-step.
  monthlySpendCapUsd       Decimal?  @map("monthly_spend_cap_usd") @db.Decimal(10, 2)
  /// Nightly eval auto-run (#303). Off by default — each run costs a few
  /// dollars at typical profile pricing. When true, worker-cron picks the
  /// org up once daily and runs the full fixture corpus against the org's
  /// default LLM profile. Results land in eval_runs with source='cron'.
  evalsEnabled             Boolean   @default(false) @map("evals_enabled")
  /// Most-recent successful eval cron tick. Used by worker-cron to dedup
  /// — a 23h-old timestamp marks the org as due. Bumped BEFORE the run
  /// fires so a flaky tick can't double-dispatch.
  evalsLastRanAt           DateTime? @map("evals_last_ran_at") @db.Timestamptz(6)
  /// Max concurrent agent steps for this org (V1.3, #9). The orchestrator
  /// counts agent_steps with status in ('pending','running') and defers
  /// new dispatches when the count is at or above this cap. 0 = unlimited
  /// (no fairness enforcement); never set this above what the runner pool
  /// can handle in steady state. NULL is treated as unlimited too — the
  /// default is set in SQL not Prisma so the migration is idempotent.
  orgConcurrencyCap        Int       @default(4) @map("org_concurrency_cap")
  complianceAuditRetention Int       @default(365) @map("compliance_audit_retention_days")
  /// Anonymous-usage telemetry opt-in (#253). Off by default — even on
  /// docker-compose.full.yml. When true, packages/telemetry emits a
  /// fixed schema of events documented in docs/03-infrastructure/07.
  telemetryEnabled         Boolean   @default(false) @map("telemetry_enabled")
  /// Per-install random uuid used as the only "identifier" on emitted
  /// telemetry events when telemetryEnabled is true. Generated lazily
  /// when the org first toggles telemetry on, so disabled orgs never
  /// pin an id at all. Never leaves this row except as the event uuid.
  telemetryInstallId       String?   @map("telemetry_install_id") @db.Uuid
  /// Operator kill switch (#625). When non-null, blocks every run-dispatch
  /// path for every project in the org: cron tick skips enqueue, the
  /// `runNow` API returns ValidationError, and the orchestrator aborts on
  /// race. In-flight runs continue — pause is forward-looking, not a kill
  /// for the running step. Org-scope pause beats project-scope pause.
  runsPausedAt             DateTime? @map("runs_paused_at") @db.Timestamptz(6)
  runsPauseReason          String?   @map("runs_pause_reason")
  runsPausedByUserId       String?   @map("runs_paused_by_user_id") @db.Uuid
  /// Slack Incoming Webhook URL (#747). Envelope-encrypted via
  /// CryptoService — same chokepoint that protects MFA secrets, LLM
  /// API keys, and project secrets. The settings UI never returns the
  /// plaintext URL; `slackWebhookCreatedAt` is the only outward signal
  /// of "configured".
  slackWebhookCiphertext   Bytes?    @map("slack_webhook_ciphertext")
  slackWebhookCreatedAt    DateTime? @map("slack_webhook_created_at") @db.Timestamptz(6)
  createdAt                DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt                DateTime? @map("deleted_at") @db.Timestamptz(6)

  memberships        Membership[]
  projects           Project[]
  llmProviders       LlmProvider[]
  llmProfiles        LlmProfile[]
  auditEntries       AuditLogEntry[]
  lifecycleTemplates OrgLifecycleTemplate[]
  apiKeys            ApiKey[]
  outboundWebhooks   OutboundWebhook[]

  @@map("organizations")
}

model OrgLifecycleTemplate {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  name           String   @default("default")
  sourceYaml     String   @map("source_yaml")
  parsed         Json
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@map("org_lifecycle_templates")
}

enum OrgRole {
  owner
  admin
  operator
  viewer

  @@map("org_role")
}

model Membership {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  role           OrgRole
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@map("memberships")
}

model AuditLogEntry {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  actorUserId    String?  @map("actor_user_id") @db.Uuid
  action         String
  target         Json
  metadata       Json     @default("{}")
  occurredAt     DateTime @default(now()) @map("occurred_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, occurredAt(sort: Desc)])
  @@map("audit_log_entries")
}

// ─────────────────────────────────────────────────────────────────────────────
// Projects
// ─────────────────────────────────────────────────────────────────────────────

model Project {
  id                 String    @id @default(uuid()) @db.Uuid
  organizationId     String    @map("organization_id") @db.Uuid
  slug               String
  name               String
  description        String?
  archivedAt         DateTime? @map("archived_at") @db.Timestamptz(6)
  /// Timestamp of the most recent end-of-day digest fan-out. Used by
  /// the worker-cron digest tick to dedup so a flaky tick doesn't
  /// send the same digest twice.
  lastDigestAt       DateTime? @map("last_digest_at") @db.Timestamptz(6)
  /// Array of `AutoPromoteRule` (#31/#150) defining which changesets
  /// can auto-promote without human review. Empty array (default) =
  /// no auto-promotion; every changeset goes through the manual gate.
  /// Validated against the Zod schema in @mergecrew/domain on writes.
  autoPromoteRules   Json      @default("[]") @map("auto_promote_rules")
  /// Egress allowlist for outbound HTTP from agent skills (#10).
  /// `null` (the default) = no restriction (back-compat). Empty array =
  /// block all. Otherwise host patterns ('example.com', '*.example.com',
  /// '*' for explicit allow-all). See packages/skills/src/egress-policy.
  egressAllowlist    Json?     @map("egress_allowlist")
  /// Dry-run mode (#284). When true, the agent loop still produces a
  /// Changeset row + diff but the runner skips git push, PR creation,
  /// and deploy. An admin can later "promote" a specific changeset to
  /// open the real PR. Lowest-risk way to try mergecrew on a real repo.
  dryRun             Boolean   @default(false) @map("dry_run")
  /// Blast-radius limits (#285). Hard caps the runner applies AFTER the
  /// agent produces a diff but BEFORE the push step. A changeset that
  /// exceeds any cap, or that touches a path matching one of the deny
  /// globs, is rejected (status=needs_review, prNumber=null) with the
  /// breakdown surfaced on the changeset detail page + inbox. Picomatch
  /// glob syntax — same as auto-promote rules.
  maxFilesChanged    Int       @default(25) @map("max_files_changed")
  maxLinesChanged    Int       @default(1000) @map("max_lines_changed")
  deniedPaths        Json      @default("[\"**/migration*\", \"**/secrets*\", \"**/.env*\", \"**/*.pem\", \"**/*.key\"]") @map("denied_paths")
  /// Risk-score gate (#286). After a changeset clears blast-radius and a
  /// PR is opened, the runner computes a simple weighted score:
  ///   score = filesChanged + linesChanged*0.1 + sensitivePathHits*10
  /// `sensitivePaths` is an OR-list of picomatch globs flagging files
  /// where a single touch matters disproportionately (config, auth,
  /// schema). A changeset whose score exceeds `autoMergeThreshold` is
  /// surfaced to the inbox as `risk_score_high` and auto-promote is
  /// suppressed even if a rule would match. Threshold=Infinity is the
  /// cheap way to disable the gate; threshold=0 makes every changeset
  /// require human review.
  autoMergeThreshold Int       @default(50) @map("auto_merge_threshold")
  sensitivePaths     Json      @default("[\"**/config/**\", \"**/auth/**\", \"**/*.sql\"]") @map("sensitive_paths")
  /// Multi-agent graph profile (#336).
  ///   - 'fast': single-agent legacy path (V1 behavior).
  ///   - 'careful': planner -> coder -> reviewer with loop-back. The
  ///     V2.ae default; still supported for backward compat.
  ///   - 'roster': full 10-agent / 6-stage lifecycle dispatched via
  ///     ROSTER_GRAPH (Discovery -> PM -> Implementation -> QA ->
  ///     DeployDev -> Observation). Default since #516 — restores the
  ///     original product design and makes the auto-applied
  ///     `roster` lifecycle template actually drive a multi-stage run.
  ///   - 'custom': use `graphYaml` below.
  /// The default flip only affects projects created after the
  /// migration; existing rows keep whatever the operator chose.
  graphProfile       String    @default("roster") @map("graph_profile")
  /// YAML body for graphProfile='custom'. Parsed + validated against
  /// the Graph schema in @mergecrew/domain on every write. Null
  /// otherwise. Operator-editable from project settings.
  graphYaml          String?   @map("graph_yaml") @db.Text
  /// Demo flag (#437). When true, this project is a read-only sample
  /// seeded for FTE walkthroughs — its runs, changesets, and timeline
  /// are illustrative. The API rejects mutations on demo projects (see
  /// `assertNotDemo` in the project module) so the read-only invariant
  /// holds even if the UI surfaces an action button. Seeded per-org on
  /// createOrg when `MERGECREW_SEED_DEMO_PROJECT=1` (default on).
  demo               Boolean   @default(false)
  /// Per-project run kill switch (#625). When non-null, blocks every
  /// run-dispatch path for this project: cron tick skips enqueue with a
  /// `paused` log line, the `runNow` API returns ValidationError surfacing
  /// the reason + actor, and the orchestrator aborts on race. In-flight
  /// runs continue — the operator can still hit Cancel on the run page.
  /// Org-scope pause on `organizations.runs_paused_at` overrides this and
  /// is checked first.
  runsPausedAt       DateTime? @map("runs_paused_at") @db.Timestamptz(6)
  runsPauseReason    String?   @map("runs_pause_reason")
  runsPausedByUserId String?   @map("runs_paused_by_user_id") @db.Uuid
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt          DateTime? @map("deleted_at") @db.Timestamptz(6)

  organization      Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  connectedRepo     ConnectedRepo?
  deployTargets     DeployTarget[]
  promotionStrategy PromotionStrategy?
  promoteRuns       PromoteRun[]
  trackerTarget     TrackerTarget?
  errorTarget       ErrorTarget?
  secrets           ProjectSecret[]
  lifecycles        Lifecycle[]
  gatePolicies      GatePolicy[]
  dailyRuns         DailyRun[]
  changesets        Changeset[]
  approvalRequests  ApprovalRequest[]
  intentItems       IntentInboxItem[]
  schedules         Schedule[]
  memoryDocs        MemoryDocument[]
  timelineEvents    TimelineEvent[]
  deploys           Deploy[]
  graphLayouts      LifecycleGraphLayout[]
  slos              ProjectSlo[]

  @@unique([organizationId, slug])
  @@map("projects")
}

model ConnectedRepo {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  projectId      String   @unique @map("project_id") @db.Uuid
  vcsProvider    String   @map("vcs_provider")
  installationId String   @map("installation_id")
  repoId         String   @map("repo_id")
  repoFullName   String   @map("repo_full_name")
  defaultBranch  String   @map("default_branch")
  /// Branch mergecrew opens new PRs against (#469). NULL coalesces to
  /// `defaultBranch` so trunk-based teams keep the old behavior. Branch-
  /// per-env shops (developer → dev, qa → stage, main → prod) point this
  /// at their integration branch.
  basePrBranch   String?  @map("base_pr_branch")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("connected_repos")
}

enum DeployTargetKind {
  dev
  staging
  prod

  @@map("deploy_target_kind")
}

enum PromotionStrategyKind {
  /// Release branch + auto-deploy. mergecrew pushes the cherry-picked
  /// release branch; the user's existing CI fires on push.
  auto_deploy
  /// Release branch + manual workflow. mergecrew pushes; user clicks a
  /// `workflow_dispatch` in GitHub (or mergecrew kicks it off if the
  /// App has the Actions:write scope).
  manual_workflow
  /// Tag-driven. mergecrew tags the release branch HEAD with an
  /// interpolated pattern; user's CI fires on tag.
  tag_driven
  /// Single-environment / pre-launch (#478). Dev IS prod. mergecrew
  /// runs no git operations on promote — the digest is purely a
  /// review gate that stamps approved changesets so they leave the
  /// inbox. Drop still opens a revert PR against basePrBranch.
  single_env
  /// Configure later. Wizard completes; project page surfaces a chip
  /// where the Promote button would be, linking back to settings.
  deferred

  @@map("promotion_strategy_kind")
}

/// V1 promotion strategy per project (#470). Captures *how* the
/// human-approved subset of dev changesets graduates to prod after the
/// cherry-pick engine (#471) builds a release ref. Nullable fields are
/// per-kind: `releaseBranch` for auto_deploy / manual_workflow,
/// `workflow*` for manual_workflow, `tagPattern` for tag_driven,
/// `prodUrl` for everything but `deferred`. Stricter validation lives
/// in the API service rather than the schema so the picker UX can be
/// edited without a migration each time.
model PromotionStrategy {
  id               String                @id @default(uuid()) @db.Uuid
  organizationId   String                @map("organization_id") @db.Uuid
  projectId        String                @unique @map("project_id") @db.Uuid
  kind             PromotionStrategyKind
  releaseBranch    String?               @map("release_branch")
  workflowFilename String?               @map("workflow_filename")
  envInputKey      String?               @map("env_input_key")
  envInputValue    String?               @map("env_input_value")
  tagPattern       String?               @map("tag_pattern")
  prodUrl          String?               @map("prod_url")
  createdAt        DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime              @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("promotion_strategies")
}

model DeployTarget {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  projectId      String           @map("project_id") @db.Uuid
  kind           DeployTargetKind
  adapterId      String           @map("adapter_id")
  config         Json
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deploys Deploy[]

  @@unique([projectId, kind])
  @@map("deploy_targets")
}

model TrackerTarget {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  projectId      String   @unique @map("project_id") @db.Uuid
  adapterId      String   @map("adapter_id")
  config         Json
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("tracker_targets")
}

/// One row per project. Stores the error-tracker (Sentry, etc.) the
/// Observation agent reads via the `errors.list_recent` skill. Token
/// goes into `project_secrets` under name `ERROR_TRACKER_TOKEN`.
model ErrorTarget {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  projectId      String   @unique @map("project_id") @db.Uuid
  adapterId      String   @map("adapter_id")
  config         Json
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("error_targets")
}

model ProjectSecret {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  projectId      String   @map("project_id") @db.Uuid
  name           String
  ciphertext     Bytes
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, name])
  @@map("project_secrets")
}

// ─────────────────────────────────────────────────────────────────────────────
// LLM providers & profiles
// ─────────────────────────────────────────────────────────────────────────────

model LlmProvider {
  id                   String   @id @default(uuid()) @db.Uuid
  organizationId       String   @map("organization_id") @db.Uuid
  kind                 String
  label                String
  endpoint             String?
  credentialCiphertext Bytes?   @map("credential_ciphertext")
  capabilityOverrides  Json?    @map("capability_overrides")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invocations  LlmInvocation[]
  modelTurns   ModelTurn[]

  @@map("llm_providers")
}

model LlmProfile {
  id                String   @id @default(uuid()) @db.Uuid
  organizationId    String   @map("organization_id") @db.Uuid
  name              String
  preferenceOrder   Json     @map("preference_order")
  capabilityRouting Json     @map("capability_routing")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@map("llm_profiles")
}

model ModelPriceTable {
  providerKind            String   @map("provider_kind")
  modelId                 String   @map("model_id")
  effectiveAt             DateTime @map("effective_at") @db.Timestamptz(6)
  inputPerMillionUsd      Decimal  @map("input_per_million_usd") @db.Decimal(10, 6)
  outputPerMillionUsd     Decimal  @map("output_per_million_usd") @db.Decimal(10, 6)
  cacheReadPerMillionUsd  Decimal? @map("cache_read_per_million_usd") @db.Decimal(10, 6)
  cacheWritePerMillionUsd Decimal? @map("cache_write_per_million_usd") @db.Decimal(10, 6)

  @@id([providerKind, modelId, effectiveAt])
  @@map("model_price_table")
}

// ─────────────────────────────────────────────────────────────────────────────
// Lifecycle & gate policies
// ─────────────────────────────────────────────────────────────────────────────

model Lifecycle {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  projectId      String   @map("project_id") @db.Uuid
  version        Int
  sourceYaml     String   @map("source_yaml")
  parsed         Json
  /// Human label for the version chain (#480). `default-bootstrap`
  /// for the autogenerated v1, the stock-template id (e.g.
  /// `generic-careful`, `nextjs-vercel`) for templated versions,
  /// NULL for hand-edited customizations.
  name           String?  @db.Text
  activeFrom     DateTime @default(now()) @map("active_from") @db.Timestamptz(6)

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  dailyRuns DailyRun[]

  @@unique([projectId, version])
  @@map("lifecycles")
}

/// Persisted node positions for the visual lifecycle editor (V2.1
/// phase 2, #195). Keyed on (projectId, workflowId) — NOT on Lifecycle
/// — so positions survive the row-replacing version bumps every YAML
/// edit produces. Only the visual layout lives here; the lifecycle DAG
/// itself is still defined by `lifecycles.parsed`.
model LifecycleGraphLayout {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  projectId      String   @map("project_id") @db.Uuid
  workflowId     String   @map("workflow_id")
  x              Int
  y              Int
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, workflowId])
  @@index([organizationId, projectId])
  @@map("lifecycle_graph_layouts")
}

model GatePolicy {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  projectId      String?  @map("project_id") @db.Uuid
  policy         Json
  version        Int
  activeFrom     DateTime @default(now()) @map("active_from") @db.Timestamptz(6)

  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("gate_policies")
}

// ─────────────────────────────────────────────────────────────────────────────
// Runs
// ─────────────────────────────────────────────────────────────────────────────

enum DailyRunStatus {
  pending
  running
  paused_rate_limit
  paused_gate
  done
  failed
  cancelled

  @@map("daily_run_status")
}

model DailyRun {
  id             String         @id @default(uuid()) @db.Uuid
  organizationId String         @map("organization_id") @db.Uuid
  projectId      String         @map("project_id") @db.Uuid
  lifecycleId    String         @map("lifecycle_id") @db.Uuid
  scheduledAt    DateTime       @map("scheduled_at") @db.Timestamptz(6)
  startedAt      DateTime?      @map("started_at") @db.Timestamptz(6)
  finishedAt     DateTime?      @map("finished_at") @db.Timestamptz(6)
  status         DailyRunStatus @default(pending)
  metadata       Json           @default("{}")

  project       Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  lifecycle     Lifecycle         @relation(fields: [lifecycleId], references: [id])
  workflowRuns  WorkflowRun[]
  changesets    Changeset[]
  pauses        RunPause[]
  intentsPicked IntentInboxItem[]
  egressEvents  EgressEvent[]

  @@index([projectId, scheduledAt(sort: Desc)])
  /// Inflight check (orchestrator.handleRunDue): "is there a non-terminal run
  /// for this project right now?" Pre-existing index didn't cover the status
  /// filter — added so the predicate hits an index-only scan.
  @@index([projectId, status, scheduledAt(sort: Desc)])
  @@map("daily_runs")
}

model WorkflowRun {
  id                  String    @id @default(uuid()) @db.Uuid
  organizationId      String    @map("organization_id") @db.Uuid
  dailyRunId          String    @map("daily_run_id") @db.Uuid
  workflowId          String    @map("workflow_id")
  parentWorkflowRunId String?   @map("parent_workflow_run_id") @db.Uuid
  status              String
  startedAt           DateTime? @map("started_at") @db.Timestamptz(6)
  finishedAt          DateTime? @map("finished_at") @db.Timestamptz(6)

  dailyRun   DailyRun      @relation(fields: [dailyRunId], references: [id], onDelete: Cascade)
  steps      AgentStep[]
  parent     WorkflowRun?  @relation("WorkflowRunParent", fields: [parentWorkflowRunId], references: [id])
  children   WorkflowRun[] @relation("WorkflowRunParent")
  changesets Changeset[]

  @@map("workflow_runs")
}

model AgentStep {
  id                String    @id @default(uuid()) @db.Uuid
  organizationId    String    @map("organization_id") @db.Uuid
  workflowRunId     String    @map("workflow_run_id") @db.Uuid
  agentKind         String    @map("agent_kind")
  agentInstanceId   String    @map("agent_instance_id") @db.Uuid
  attempt           Int       @default(1)
  status            String
  input             Json
  output            Json?
  failureReason     String?   @map("failure_reason")
  startedAt         DateTime? @map("started_at") @db.Timestamptz(6)
  finishedAt        DateTime? @map("finished_at") @db.Timestamptz(6)
  totalInputTokens  Int       @default(0) @map("total_input_tokens")
  totalOutputTokens Int       @default(0) @map("total_output_tokens")
  totalUsdEstimate  Decimal   @default(0) @map("total_usd_estimate") @db.Decimal(12, 6)
  /// Pointer to the agent's full message transcript (#4). Format is the
  /// scheme-prefixed location: `s3://bucket/key`, `file:///path`, etc.
  /// Null when the runner couldn't persist (no S3 + no local dir, or
  /// the step never produced messages — e.g. cancelled before LLM call).
  transcriptUrl     String?   @map("transcript_url")

  /// Liveness heartbeat (#10 V1.4). Stamped every RUNNER_HEARTBEAT_INTERVAL_MS
  /// while a step is executing. The orchestrator's heartbeat sweeper
  /// re-dispatches steps whose heartbeat has gone stale, on the assumption
  /// that the runner died (OOM, ECS task killed, network partition).
  /// Null while the step is queued/pending; cleared lazily on terminal
  /// states. Index is partial-friendly because the sweeper only ever scans
  /// rows with status='running'.
  heartbeatAt DateTime? @map("heartbeat_at") @db.Timestamptz(6)

  /// Multi-agent graph node key (#331). Null for legacy single-agent runs.
  /// Set by the runner when a step is produced by a named node in a
  /// project's graph profile — e.g. 'planner', 'coder', 'reviewer'. The
  /// run-detail UI groups steps by this key to render per-agent costs.
  graphNodeKey String? @map("graph_node_key")

  workflowRun  WorkflowRun   @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)
  toolCalls    ToolCall[]
  modelTurns   ModelTurn[]
  pauses       RunPause[]
  egressEvents EgressEvent[]

  @@index([status, startedAt])
  @@index([status, heartbeatAt])
  @@map("agent_steps")
}

model ToolCall {
  id              String    @id @default(uuid()) @db.Uuid
  organizationId  String    @map("organization_id") @db.Uuid
  agentStepId     String    @map("agent_step_id") @db.Uuid
  sequence        Int
  skillName       String    @map("skill_name")
  input           Json
  output          Json?
  isError         Boolean   @default(false) @map("is_error")
  startedAt       DateTime  @map("started_at") @db.Timestamptz(6)
  finishedAt      DateTime? @map("finished_at") @db.Timestamptz(6)
  sideEffectClass String    @map("side_effect_class")

  step AgentStep @relation(fields: [agentStepId], references: [id], onDelete: Cascade)

  @@unique([agentStepId, sequence])
  @@map("tool_calls")
}

model ModelTurn {
  id                 String   @id @default(uuid()) @db.Uuid
  organizationId     String   @map("organization_id") @db.Uuid
  agentStepId        String   @map("agent_step_id") @db.Uuid
  sequence           Int
  providerId         String   @map("provider_id") @db.Uuid
  modelId            String   @map("model_id")
  inputTokens        Int      @map("input_tokens")
  outputTokens       Int      @map("output_tokens")
  cacheReadTokens    Int      @default(0) @map("cache_read_tokens")
  cacheWriteTokens   Int      @default(0) @map("cache_write_tokens")
  thinkingTokens     Int?     @map("thinking_tokens")
  latencyMs          Int      @map("latency_ms")
  usdEstimate        Decimal  @map("usd_estimate") @db.Decimal(12, 6)
  rawRequestBlobUrl  String?  @map("raw_request_blob_url")
  rawResponseBlobUrl String?  @map("raw_response_blob_url")
  occurredAt         DateTime @default(now()) @map("occurred_at") @db.Timestamptz(6)

  step     AgentStep   @relation(fields: [agentStepId], references: [id], onDelete: Cascade)
  provider LlmProvider @relation(fields: [providerId], references: [id])

  @@unique([agentStepId, sequence])
  @@map("model_turns")
}

model LlmInvocation {
  id               String   @id @default(uuid()) @db.Uuid
  organizationId   String   @map("organization_id") @db.Uuid
  projectId        String   @map("project_id") @db.Uuid
  runId            String?  @map("run_id") @db.Uuid
  agentStepId      String?  @map("agent_step_id") @db.Uuid
  providerId       String   @map("provider_id") @db.Uuid
  modelId          String   @map("model_id")
  inputTokens      Int      @map("input_tokens")
  outputTokens     Int      @map("output_tokens")
  cacheReadTokens  Int      @default(0) @map("cache_read_tokens")
  cacheWriteTokens Int      @default(0) @map("cache_write_tokens")
  thinkingTokens   Int?     @map("thinking_tokens")
  latencyMs        Int      @map("latency_ms")
  usdEstimate      Decimal  @map("usd_estimate") @db.Decimal(12, 6)
  occurredAt       DateTime @default(now()) @map("occurred_at") @db.Timestamptz(6)

  provider LlmProvider @relation(fields: [providerId], references: [id])

  @@index([organizationId, occurredAt(sort: Desc)])
  @@index([projectId, occurredAt(sort: Desc)])
  @@map("llm_invocations")
}

/// Outbound network attempt recorded during a run (#576).
///
/// Captured at the skill layer (`packages/skills/src/egress-policy.ts`)
/// for every HTTP-bound stock or custom skill call: host, decision
/// (allowed | blocked), the reason the decision was reached, the skill
/// that made the attempt, and the agent step it occurred under.
///
/// Future sources (sandbox proxy / DNS / nftables) will write to the
/// same table — the `source` discriminator tells the UI whether the
/// attempt came from Node code or from inside the sandbox.
model EgressEvent {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  dailyRunId     String   @map("daily_run_id") @db.Uuid
  agentStepId    String?  @map("agent_step_id") @db.Uuid
  /// Where the decision came from: 'skill' (Node-level assertEgressAllowed),
  /// 'sandbox.proxy' (#575), 'sandbox.dns' (#574), 'sandbox.netfilter' (#573).
  source         String
  /// Skill name (when source='skill') or sidecar name otherwise.
  origin         String?
  /// Lower-cased hostname the build/skill tried to reach.
  host           String
  port           Int?
  method         String?
  /// 'allowed' | 'blocked'
  decision       String
  /// Short tag: 'allowlist' | 'wildcard' | 'unlisted' | 'loopback' | 'private' | 'parse_error' | 'other'
  reason         String
  /// Audit vs enforced mode (#576). V0 is always 'enforced' — skills
  /// throw EgressBlocked synchronously. When the proxy gains an audit
  /// mode (it logs but doesn't drop), entries from there land as
  /// 'audit' so the UI can render the "would have been blocked" chip.
  mode           String   @default("enforced")
  occurredAt     DateTime @default(now()) @map("occurred_at") @db.Timestamptz(6)

  dailyRun DailyRun   @relation(fields: [dailyRunId], references: [id], onDelete: Cascade)
  step     AgentStep? @relation(fields: [agentStepId], references: [id], onDelete: SetNull)

  @@index([dailyRunId, occurredAt(sort: Desc)])
  @@index([dailyRunId, decision, host])
  @@map("egress_events")
}

model RunPause {
  id                String    @id @default(uuid()) @db.Uuid
  organizationId    String    @map("organization_id") @db.Uuid
  dailyRunId        String    @map("daily_run_id") @db.Uuid
  stepId            String?   @map("step_id") @db.Uuid
  kind              String
  providerId        String?   @map("provider_id") @db.Uuid
  approvalRequestId String?   @map("approval_request_id") @db.Uuid
  pausedAt          DateTime  @default(now()) @map("paused_at") @db.Timestamptz(6)
  wakeAt            DateTime? @map("wake_at") @db.Timestamptz(6)
  resumedAt         DateTime? @map("resumed_at") @db.Timestamptz(6)

  dailyRun DailyRun   @relation(fields: [dailyRunId], references: [id], onDelete: Cascade)
  step     AgentStep? @relation(fields: [stepId], references: [id])

  @@index([wakeAt])
  @@map("run_pauses")
}

/// Pre-aggregated telemetry buckets (V2.af / #742). Two granularities —
/// `hour` and `day` — keyed on (org, project?, granularity, bucket). The
/// project_id-null branch holds org-wide rollups; the project-scoped
/// branch holds per-project rollups for the same window. UPSERTed by the
/// worker-cron `metricsRollupTick`; read by the org/project metrics
/// pages, the SLO evaluator, and the project health badges.
model MetricsRollup {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  projectId      String?  @map("project_id") @db.Uuid
  /// 'hour' or 'day'. Enforced in SQL by a CHECK constraint.
  granularity    String
  /// UTC instant at the start of the bucket (truncated to the hour or day).
  bucket         DateTime @db.Timestamptz(6)
  runsStarted    Int      @default(0) @map("runs_started")
  runsCompleted  Int      @default(0) @map("runs_completed")
  runsFailed     Int      @default(0) @map("runs_failed")
  stepsRun       Int      @default(0) @map("steps_run")
  stepsPassed    Int      @default(0) @map("steps_passed")
  p50StepMs      Int      @default(0) @map("p50_step_ms")
  p95StepMs      Int      @default(0) @map("p95_step_ms")
  llmTokensIn    BigInt   @default(0) @map("llm_tokens_in")
  llmTokensOut  BigInt   @default(0) @map("llm_tokens_out")
  costUsdCents   BigInt   @default(0) @map("cost_usd_cents")
  computedAt     DateTime @default(now()) @map("computed_at") @db.Timestamptz(6)

  @@index([organizationId, granularity, bucket(sort: Desc)])
  @@index([projectId, granularity, bucket(sort: Desc)])
  @@map("metrics_rollups")
}

/// Per-project SLO target (V2.af / #745). The evaluator
/// (`worker-cron/slo-evaluator-tick`) reads recent MetricsRollup rows
/// for each enabled SLO, computes the current state (OK / AT_RISK /
/// BREACHING / INSUFFICIENT_DATA), and emits a TimelineEvent of type
/// `slo.transitioned` when the state changes. Current state is derived
/// from the timeline on read — not stored here — so the UI has a
/// single source of truth.
model ProjectSlo {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  projectId      String   @map("project_id") @db.Uuid
  name           String
  /// One of: 'stepPassRate' | 'runFailureRate' | 'p95StepMs' | 'dailyCostUsd'.
  /// Enforced in SQL by a CHECK constraint.
  metric         String
  /// 'gte' (actual must be ≥ threshold) or 'lte' (actual must be ≤ threshold).
  comparator     String
  /// Compared against the metric in the metric's natural unit
  /// (percent for rates, ms for latency, USD for cost).
  threshold      Decimal  @db.Decimal(12, 4)
  windowHours    Int      @map("window_hours")
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, enabled])
  @@map("project_slos")
}

// ─────────────────────────────────────────────────────────────────────────────
// Eval harness (V2.ab, #299)
// ─────────────────────────────────────────────────────────────────────────────

model EvalRun {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  llmProfileId   String?   @map("llm_profile_id") @db.Uuid
  /// What triggered this run. `cli` = `pnpm eval run`; `cron` = nightly
  /// scheduler (#303); `ab` = paired half of an A/B compare (#302).
  source         String
  startedAt      DateTime  @default(now()) @map("started_at") @db.Timestamptz(6)
  finishedAt     DateTime? @map("finished_at") @db.Timestamptz(6)
  totalCases     Int       @default(0) @map("total_cases")
  passCount      Int       @default(0) @map("pass_count")
  failCount      Int       @default(0) @map("fail_count")
  errorCount     Int       @default(0) @map("error_count")
  totalUsd       Decimal   @default(0) @map("total_usd") @db.Decimal(12, 6)
  totalLatencyMs Int       @default(0) @map("total_latency_ms")

  cases EvalCase[]

  @@index([organizationId, startedAt(sort: Desc)])
  @@map("eval_runs")
}

model EvalCase {
  id           String   @id @default(uuid()) @db.Uuid
  evalRunId    String   @map("eval_run_id") @db.Uuid
  /// Matches `manifest.id` from @mergecrew/eval-fixtures.
  fixtureId    String   @map("fixture_id")
  /// `pass` = snapshot comparison agreed; `fail` = disagreed; `error`
  /// = the harness itself crashed (provider error, timeout, etc.).
  status       String
  agentDiff    String?  @map("agent_diff") @db.Text
  errorMessage String?  @map("error_message") @db.Text
  usdEstimate  Decimal  @default(0) @map("usd_estimate") @db.Decimal(12, 6)
  latencyMs    Int      @default(0) @map("latency_ms")
  finishedAt   DateTime @default(now()) @map("finished_at") @db.Timestamptz(6)

  run EvalRun @relation(fields: [evalRunId], references: [id], onDelete: Cascade)

  @@index([evalRunId])
  @@map("eval_cases")
}

/// Pair of EvalRuns produced by a single `--ab` invocation (#302).
/// Both child runs see the same fixture corpus; the comparison page
/// reads the two side-by-side. `profileAId` / `profileBId` carry the
/// LLM profile each side used — the runs themselves also link back
/// via llmProfileId but having it on the parent saves a join.
model EvalAbRun {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  profileAId     String    @map("profile_a_id") @db.Uuid
  profileBId     String    @map("profile_b_id") @db.Uuid
  runAId         String    @map("run_a_id") @db.Uuid
  runBId         String    @map("run_b_id") @db.Uuid
  startedAt      DateTime  @default(now()) @map("started_at") @db.Timestamptz(6)
  finishedAt     DateTime? @map("finished_at") @db.Timestamptz(6)

  @@index([organizationId, startedAt(sort: Desc)])
  @@map("eval_ab_runs")
}

// ─────────────────────────────────────────────────────────────────────────────
// Changesets, deploys, decisions, approvals
// ─────────────────────────────────────────────────────────────────────────────

enum ChangesetStatus {
  proposed
  building
  testing
  tests_failed
  pr_open
  dev_deployed
  promoted
  rolled_back
  deferred
  /// Blast-radius limit hit (#285) — files/LOC over cap, or a path
  /// matched a deny glob. The changeset stays visible with the rejection
  /// breakdown on its detail page; no PR is opened, no deploy fires.
  blocked

  @@map("changeset_status")
}

model Changeset {
  id                 String          @id
  organizationId     String          @map("organization_id") @db.Uuid
  projectId          String          @map("project_id") @db.Uuid
  dailyRunId         String          @map("daily_run_id") @db.Uuid
  workflowRunId      String?         @map("workflow_run_id") @db.Uuid
  title              String
  whyParagraph       String?         @map("why_paragraph") @db.Text
  branch             String
  status             ChangesetStatus @default(proposed)
  prNumber           Int?            @map("pr_number")
  prUrl              String?         @map("pr_url")
  devDeployId        String?         @map("dev_deploy_id") @db.Uuid
  testSummary        Json?           @map("test_summary")
  riskChip           String?         @map("risk_chip")
  estimatedUsd       Decimal         @default(0) @map("estimated_usd") @db.Decimal(12, 6)
  /// True when the parent project was in dry-run mode (#284) at the
  /// moment the agent produced this changeset. The runner sets it once
  /// at creation; toggling project.dryRun afterwards does NOT rewrite
  /// existing changesets. Operators promote a dry-run changeset via the
  /// changeset detail page → "Promote to real PR" button.
  isDryRun           Boolean         @default(false) @map("is_dry_run")
  /// Blast-radius rejection breakdown (#285). Set when status=blocked.
  /// Shape: {kind:'files'|'lines'|'denied_paths', filesChanged?, maxFiles?,
  /// linesChanged?, maxLines?, deniedHits?:[{path,glob}]}. Null otherwise.
  blockedReason      Json?           @map("blocked_reason")
  /// Risk score (#286) — null until the post-push gate evaluates the
  /// changeset. Higher = more attention needed. Compared against the
  /// project's autoMergeThreshold to decide auto-promote eligibility.
  riskScore          Float?          @map("risk_score")
  /// Per-component breakdown the inbox + detail page render so operators
  /// see WHY a score is high. Shape: {filesChanged,linesChanged,
  /// sensitiveHits:[{path,glob}]}.
  riskScoreBreakdown Json?           @map("risk_score_breakdown")
  /// One-click rollback target (#287). When an admin rolls back a
  /// merged changeset we open a `git revert` PR via the VCS adapter
  /// and stamp its number + URL here so the detail page can link to
  /// the active revert without re-querying the host.
  revertPrNumber     Int?            @map("revert_pr_number")
  revertPrUrl        String?         @map("revert_pr_url")
  /// Which PromoteRun (#471) shipped this changeset to prod. Null
  /// while pending / deferred / dropped.
  lastPromoteRunId   String?         @map("last_promote_run_id") @db.Uuid
  /// When the user clicked Drop in the promote digest (#471). Once set,
  /// the changeset is excluded from all subsequent promote digests.
  droppedAt          DateTime?       @map("dropped_at") @db.Timestamptz(6)
  /// URL of the revert PR mergecrew opened on basePrBranch when the
  /// user dropped this changeset (#471). Idempotent: re-dropping
  /// returns this same PR rather than opening a duplicate.
  dropRevertPrUrl    String?         @map("drop_revert_pr_url")
  createdAt          DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  project          Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  dailyRun         DailyRun           @relation(fields: [dailyRunId], references: [id], onDelete: Cascade)
  workflowRun      WorkflowRun?       @relation(fields: [workflowRunId], references: [id])
  decisions        Decision[]
  deploys          Deploy[]
  approvalRequests ApprovalRequest[]
  comments         ChangesetComment[]
  lastPromoteRun   PromoteRun?        @relation(fields: [lastPromoteRunId], references: [id])

  @@index([projectId, status, updatedAt(sort: Desc)])
  @@map("changesets")
}

enum PromoteRunStatus {
  pending
  conflict
  completed
  failed

  @@map("promote_run_status")
}

/// One row per "build a release artifact" attempt (#471). The engine
/// cherry-picks the human-approved subset of dev changesets onto a
/// release branch, then triggers the user's CI per PromotionStrategy.
/// `conflict` means the engine stopped on a cherry-pick conflict; the
/// release branch is left on the remote for the human to resolve and
/// the user can re-run with the same approved set after fixing it.
model PromoteRun {
  id                   String           @id @default(uuid()) @db.Uuid
  organizationId       String           @map("organization_id") @db.Uuid
  projectId            String           @map("project_id") @db.Uuid
  status               PromoteRunStatus @default(pending)
  /// Branch / tag name on the remote that the human-approved subset
  /// landed on. Null until the cherry-pick at least produces a branch.
  releaseRef           String?          @map("release_ref")
  approvedChangesetIds Json             @map("approved_changeset_ids")
  /// `{ changesetId, files: string[] }` when status = conflict, else
  /// null. The UI re-uses this to surface a resolution affordance.
  conflict             Json?
  /// Error string when status = failed. Free-form so we can capture
  /// push errors, dispatch failures, etc.
  failureReason        String?          @map("failure_reason")
  createdAt            DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  finishedAt           DateTime?        @map("finished_at") @db.Timestamptz(6)

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  changesets Changeset[]

  @@index([projectId, createdAt(sort: Desc)])
  @@map("promote_runs")
}

model Deploy {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  projectId      String    @map("project_id") @db.Uuid
  changesetId    String?   @map("changeset_id")
  deployTargetId String    @map("deploy_target_id") @db.Uuid
  ref            String
  correlationId  String    @map("correlation_id")
  externalRunId  String?   @map("external_run_id")
  url            String?
  status         String
  startedAt      DateTime  @map("started_at") @db.Timestamptz(6)
  finishedAt     DateTime? @map("finished_at") @db.Timestamptz(6)

  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  changeset    Changeset?   @relation(fields: [changesetId], references: [id])
  deployTarget DeployTarget @relation(fields: [deployTargetId], references: [id])

  @@unique([projectId, correlationId])
  @@map("deploys")
}

model Decision {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  changesetId    String   @map("changeset_id")
  userId         String   @map("user_id") @db.Uuid
  kind           String
  comment        String?  @db.Text
  occurredAt     DateTime @default(now()) @map("occurred_at") @db.Timestamptz(6)

  changeset Changeset @relation(fields: [changesetId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id])

  @@map("decisions")
}

/// One row per active single-use recovery code. SHA-256 of the code, so
/// the cleartext only exists in the response that issues them. Consuming
/// a code deletes the row.
model UserMfaRecoveryCode {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  codeHash  String   @unique @map("code_hash")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_mfa_recovery_codes")
}

/// Reviewer comments on a pending changeset, anchored to a file + line
/// range in the diff. Threaded via parentId self-reference. Resolved
/// state is per-thread; unresolved comments become reviewer feedback the
/// implementing agent reads on the next iteration (#111).
model ChangesetComment {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  changesetId    String    @map("changeset_id")
  userId         String    @map("user_id") @db.Uuid
  filePath       String    @map("file_path")
  /// `{ startLine: number, endLine: number }` — both 1-indexed; null for a
  /// file-level comment that doesn't anchor to a specific range.
  lineRange      Json?     @map("line_range")
  body           String    @db.Text
  parentId       String?   @map("parent_id") @db.Uuid
  resolvedAt     DateTime? @map("resolved_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  changeset Changeset          @relation(fields: [changesetId], references: [id], onDelete: Cascade)
  user      User               @relation(fields: [userId], references: [id])
  parent    ChangesetComment?  @relation("ChangesetCommentReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies   ChangesetComment[] @relation("ChangesetCommentReplies")

  @@index([changesetId, filePath, createdAt])
  @@map("changeset_comments")
}

model ApprovalRequest {
  id               String    @id @default(uuid()) @db.Uuid
  organizationId   String    @map("organization_id") @db.Uuid
  projectId        String    @map("project_id") @db.Uuid
  workflowRunId    String    @map("workflow_run_id") @db.Uuid
  changesetId      String?   @map("changeset_id")
  reason           String
  details          Json
  requiredRole     String    @map("required_role")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  resolvedAt       DateTime? @map("resolved_at") @db.Timestamptz(6)
  resolvedByUserId String?   @map("resolved_by_user_id") @db.Uuid
  resolution       String?

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  changeset Changeset? @relation(fields: [changesetId], references: [id])
  resolver  User?      @relation("ApprovalResolvedBy", fields: [resolvedByUserId], references: [id])

  @@index([projectId, resolvedAt])
  @@map("approval_requests")
}

model IntentInboxItem {
  id                String   @id @default(uuid()) @db.Uuid
  organizationId    String   @map("organization_id") @db.Uuid
  projectId         String   @map("project_id") @db.Uuid
  /// Nullable for system-originated intents (Sentry webhook, etc.).
  submittedByUserId String?  @map("submitted_by_user_id") @db.Uuid
  body              String   @db.Text
  status            String   @default("queued")
  /// Optional source tag, e.g. `sentry:issue:1234`. Used by webhook
  /// dedup to suppress duplicate intents within a short window.
  sourceKey         String?  @map("source_key")
  pickedUpRunId     String?  @map("picked_up_run_id") @db.Uuid
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user        User?     @relation(fields: [submittedByUserId], references: [id])
  pickedUpRun DailyRun? @relation(fields: [pickedUpRunId], references: [id])

  @@index([projectId, status, createdAt])
  @@index([projectId, sourceKey, createdAt])
  @@map("intent_inbox_items")
}

// ─────────────────────────────────────────────────────────────────────────────
// Schedules
// ─────────────────────────────────────────────────────────────────────────────

model Schedule {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  projectId      String    @unique @map("project_id") @db.Uuid
  cron           String    @default("0 8 * * 1-5")
  timezone       String    @default("UTC")
  enabled        Boolean   @default(true)
  /// Per-project list of `YYYY-MM-DD` dates the scheduler must skip (holidays,
  /// freezes, etc.). Compared in the schedule's tz by the worker-cron tick.
  skipDates      String[]  @default([]) @map("skip_dates")
  lastFiredAt    DateTime? @map("last_fired_at") @db.Timestamptz(6)
  /// Set by worker-cron when a tick that would have fired was skipped
  /// (currently: project paused — no connectedRepo or no dev deploy
  /// target, per #246). UI reads this to tell the operator "your cron
  /// did run, but nothing happened, and here's why" instead of just
  /// showing a stale `lastFiredAt`.
  lastSkippedAt  DateTime? @map("last_skipped_at") @db.Timestamptz(6)
  nextFireAt     DateTime? @map("next_fire_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([nextFireAt])
  /// worker-cron tick scans `where: { enabled: true }` every minute. Once
  /// disabled rows accumulate, the partial-style filter benefits from an
  /// index seek on enabled.
  @@index([enabled])
  @@map("schedules")
}

// ─────────────────────────────────────────────────────────────────────────────
// Timeline & memory
// ─────────────────────────────────────────────────────────────────────────────

model TimelineEvent {
  id             BigInt   @id @default(autoincrement())
  eventId        String   @unique @map("event_id") @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  projectId      String   @map("project_id") @db.Uuid
  dailyRunId     String?  @map("daily_run_id") @db.Uuid
  workflowRunId  String?  @map("workflow_run_id") @db.Uuid
  agentStepId    String?  @map("agent_step_id") @db.Uuid
  changesetId    String?  @map("changeset_id")
  parentEventId  String?  @map("parent_event_id") @db.Uuid
  type           String
  actor          Json
  payload        Json
  occurredAt     DateTime @map("occurred_at") @db.Timestamptz(6)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([dailyRunId, occurredAt(sort: Desc)])
  @@index([projectId, occurredAt(sort: Desc)])
  /// SSE replay path: `where: { dailyRunId, id > marker } orderBy: id asc`.
  /// The PK already covers the order; this composite lets the planner seek
  /// directly to the marker without scanning the run's whole history when
  /// the run gets long.
  @@index([dailyRunId, id])
  @@map("timeline_events")
}

model MemoryDocument {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  projectId      String   @map("project_id") @db.Uuid
  collection     String
  content        String   @db.Text
  // Vector embedding column added by raw SQL migration; see migrations/00_init.
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, collection])
  @@map("memory_documents")
}

// ─────────────────────────────────────────────────────────────────────────────
// Sessions for NextAuth (kept here so all persistence is under one roof)
// ─────────────────────────────────────────────────────────────────────────────

model AuthAccount {
  id                String  @id @default(uuid()) @db.Uuid
  userId            String  @map("user_id") @db.Uuid
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refreshToken      String? @map("refresh_token") @db.Text
  accessToken       String? @map("access_token") @db.Text
  expiresAt         Int?    @map("expires_at")
  tokenType         String? @map("token_type")
  scope             String?
  idToken           String? @map("id_token") @db.Text
  sessionState      String? @map("session_state")

  @@unique([provider, providerAccountId])
  @@map("auth_accounts")
}

model AuthSession {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime @db.Timestamptz(6)

  @@map("auth_sessions")
}

model AuthVerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime @db.Timestamptz(6)

  @@unique([identifier, token])
  @@map("auth_verification_tokens")
}

/// Outbound webhook subscription (#141). Each row is one URL the org
/// wants notified when matching events fire on the timeline. Secret is
/// random per-row and used to HMAC-sign each delivery body (#142).
model OutboundWebhook {
  id              String    @id @default(uuid()) @db.Uuid
  organizationId  String    @map("organization_id") @db.Uuid
  url             String
  /// 32-byte random per-webhook secret used for HMAC-SHA-256 signing.
  /// Returned to the issuer ONCE on create; DB never reveals it again.
  secret          String
  /// JSON array of timeline event types to deliver, e.g.
  /// ["RUN_COMPLETED","CHANGESET_OPENED"]. Empty array = all events.
  events          Json      @default("[]")
  enabled         Boolean   @default(true)
  createdByUserId String?   @map("created_by_user_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  lastDeliveredAt DateTime? @map("last_delivered_at") @db.Timestamptz(6)
  failureCount    Int       @default(0) @map("failure_count")

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deliveries   WebhookDelivery[]

  @@index([organizationId])
  @@map("outbound_webhooks")
}

/// Per-attempt delivery log for outbound webhooks. Bounded retention
/// (the worker trims to the last N per webhook on each insert).
model WebhookDelivery {
  id           String   @id @default(uuid()) @db.Uuid
  webhookId    String   @map("webhook_id") @db.Uuid
  /// Same UUID as the X-Mergecrew-Delivery header sent to the receiver,
  /// so they can dedupe on retries.
  deliveryUuid String   @unique @map("delivery_uuid") @db.Uuid
  eventType    String   @map("event_type")
  /// Null until the request returns (or the worker gives up).
  statusCode   Int?     @map("status_code")
  attempt      Int      @default(1)
  occurredAt   DateTime @default(now()) @map("occurred_at") @db.Timestamptz(6)
  errorMessage String?  @map("error_message")

  webhook OutboundWebhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId, occurredAt(sort: Desc)])
  @@map("webhook_deliveries")
}

/// API keys for programmatic access (#138). The plaintext token is shown
/// once at creation; we store sha256(token) so revocation is final and the
/// DB never holds a usable secret. `prefix` is the public-facing display
/// portion (`mc_live_abcd…`) shown in the UI; `role` is the org role the
/// key acts as for authz.
model ApiKey {
  id              String    @id @default(uuid()) @db.Uuid
  organizationId  String    @map("organization_id") @db.Uuid
  name            String
  /// sha256(token) hex — the only persisted form of the secret.
  tokenHash       String    @unique @map("token_hash")
  /// First ~12 chars of the issued token, for UI display only.
  prefix          String
  role            OrgRole   @default(operator)
  createdByUserId String?   @map("created_by_user_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  lastUsedAt      DateTime? @map("last_used_at") @db.Timestamptz(6)
  revokedAt       DateTime? @map("revoked_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("api_keys")
}
