{
  "name": "@mergecrew/sdk",
  "version": "0.1.0",
  "description": "Official TypeScript SDK for the Mergecrew API.",
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "generate": "openapi-typescript ../../docs/openapi.json -o src/generated.ts"
  },
  "dependencies": {
    "openapi-fetch": "^0.13.4"
  },
  "devDependencies": {
    "openapi-typescript": "^7.4.4",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
