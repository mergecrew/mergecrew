# syntax=docker/dockerfile:1.7
ARG NODE_VERSION=22-bookworm-slim

FROM node:${NODE_VERSION} AS base
RUN corepack enable
WORKDIR /repo

FROM base AS deps
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml* tsconfig.base.json ./
COPY apps/web/package.json apps/web/
COPY packages/ packages/
RUN --mount=type=cache,target=/root/.local/share/pnpm/store,id=pnpm-store \
    pnpm install --frozen-lockfile=false

FROM deps AS build
COPY . .
# `@mergecrew/web...` (trailing dots = pnpm filter syntax for "this and
# its workspace dependencies") so @mergecrew/domain et al. emit their
# dist/ before next build tries to resolve them.
RUN pnpm --filter @mergecrew/web... build

FROM node:${NODE_VERSION} AS runtime
WORKDIR /app
COPY --from=build /repo/apps/web/.next/standalone /app
COPY --from=build /repo/apps/web/.next/static /app/apps/web/.next/static
# Static assets served at /<path> (#642 added the landing screenshots
# at /landing/*.png). Without this COPY the standalone bundle serves
# the page but every public asset 404s.
COPY --from=build /repo/apps/web/public /app/apps/web/public
EXPOSE 3000
USER node
CMD ["node", "apps/web/server.js"]
