{
  "name": "mergecrew",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "dotenv -e .env -- turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write .",
    "bootstrap": "tsx scripts/bootstrap.ts",
    "telemetry:preview": "dotenv -e .env -- tsx scripts/telemetry-preview.ts",
    "db:migrate": "dotenv -e .env -- pnpm --filter @mergecrew/db migrate",
    "db:generate": "dotenv -e .env -- pnpm --filter @mergecrew/db generate",
    "db:seed": "dotenv -e .env -- pnpm --filter @mergecrew/db seed",
    "db:reset": "dotenv -e .env -- pnpm --filter @mergecrew/db reset",
    "compose:up": "docker compose -f docker-compose.yml up -d",
    "compose:down": "docker compose -f docker-compose.yml down",
    "compose:full": "docker compose -f docker-compose.full.yml up",
    "compose:full:down": "docker compose -f docker-compose.full.yml down",
    "e2e:local": "bash scripts/e2e-local.sh"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.12.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "turbo": "^2.9.12",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  },
  "pnpm": {
    "patchedDependencies": {}
  }
}
