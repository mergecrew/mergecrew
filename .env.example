# --- Core ---
NODE_ENV=development

# --- Database ---
# DATABASE_URL is the runtime app connection (no RLS bypass). The
# canonical setup points it at the `mergecrew_app` role.
DATABASE_URL=postgresql://mergecrew:mergecrew@localhost:5432/mergecrew?schema=public
# DATABASE_MIGRATE_URL runs Prisma migrations and is also used as the
# default for cross-tenant system queries (org creation, org-by-slug
# auth lookups, "what orgs does this user belong to" — all the paths
# that need to read across tenants). Should be a `BYPASSRLS` role.
DATABASE_MIGRATE_URL=postgresql://mergecrew_migrator:mergecrew_migrator@localhost:5432/mergecrew?schema=public
# Optional override: a dedicated `BYPASSRLS` role used only for the
# system-query path (separate from migrations). Falls back to
# DATABASE_MIGRATE_URL when unset.
# DATABASE_SYSTEM_URL=

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Object storage (LocalStack-friendly) ---
S3_ENDPOINT=http://localhost:4566
S3_REGION=us-east-1
S3_BUCKET=mergecrew-artifacts-dev
S3_FORCE_PATH_STYLE=true
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=us-east-1

# --- Auth ---
# Dev auto-login: when true, the web app skips OAuth and signs in as
# MERGECREW_DEV_USER_EMAIL automatically. Default: true unless NODE_ENV=production.
MERGECREW_DEV_AUTO_LOGIN=true
MERGECREW_DEV_USER_EMAIL=demo@mergecrew.local
MERGECREW_DEV_USER_NAME=Demo User
BFF_TRUST_TOKEN=dev-trust-token

JWT_SECRET=change-me-in-prod
JWT_ISSUER=mergecrew
JWT_AUDIENCE=mergecrew
NEXTAUTH_SECRET=change-me-in-prod
NEXTAUTH_URL=http://localhost:3000

# OAuth (only needed if MERGECREW_DEV_AUTO_LOGIN=false)
# GitHub sign-in reuses the GitHub App's client id/secret below — there's
# no separate OAuth App. Set the App's "Identifying and authorizing users"
# callback URL to <NEXTAUTH_URL>/api/auth/callback/github.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- GitHub App (for repo integration) ---
# The App's `mergecrew/<slug>` part of the URL — used to render install links
# in the UI (e.g. "Install on a repo" CTA). Optional but recommended.
GITHUB_APP_SLUG=mergecrew
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
# Two ways to provide the private key — pick one. Preferred for prod is
# `_FILE`: mount the .pem read-only into the container (see
# `docker-compose.prod.yml` — `./secrets:/app/secrets:ro`) and point this var
# at the path inside the container, e.g. `/app/secrets/github-app.pem`.
GITHUB_APP_PRIVATE_KEY_FILE=
# Inline PEM, used when `_FILE` is unset. Wrap the multi-line PEM in
# double quotes so dotenv (and docker compose v2.x) preserve the real
# newlines, e.g.
#   GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
#   MIIEowIBAAKCAQEA…
#   -----END RSA PRIVATE KEY-----"
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=

# --- LLM providers (BYOK; can be left blank in dev) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_URL=http://localhost:11434
BEDROCK_REGION=us-east-1

# --- Demo mode (V2.ag, #374) ---
# When `1`, the agent runtime bypasses the LLM and returns deterministic
# per-kind output (planner emits a canned plan, coder no-ops + runner
# synthesizes a placeholder Changeset, reviewer emits VERDICT: approve).
# Lets a self-host operator click "Run now" on the demo project
# without configuring any LLM provider. The web UI shows an amber
# banner so the mode is unambiguous. Set to `0` once a real LLM is
# wired in. Defaults to `1` in docker-compose.full.yml.
MERGECREW_DEMO_MODE=1
# Optional: when MERGECREW_DEMO_MODE=1 and the agent kind is Reviewer,
# overrides the canned verdict to exercise the reviewer→coder
# loop-back path (V2.ae #349). Leave unset for the default "approve"
# happy path.
# MERGECREW_STUB_REVIEWER_VERDICT=request_changes

# --- Deploy adapters ---
VERCEL_TOKEN=

# --- Internal services ---
API_BASE_URL=http://localhost:4000
WEB_BASE_URL=http://localhost:3000

# --- Email (digest emails + magic-link sign-in) ---
# Two providers are supported: SMTP (via nodemailer) and Resend
# (https://resend.com). Pick one. When both are set, EMAIL_PROVIDER
# decides; the default 'auto' prefers Resend. Leave both unset in dev —
# emails are dumped to the API server console instead of being sent.
#
# SMTP option. Mailpit (https://github.com/axllent/mailpit) is a good
# dev relay; Postmark / SES / etc. work for prod.
#   SMTP_URL=smtps://user:pass@smtp.example.com:465
#   SMTP_URL=smtp://localhost:1025
SMTP_URL=
#
# Resend option (https://resend.com). Free tier covers low-volume OSS
# installs. Get a key at https://resend.com/api-keys — verify your
# sending domain first.
#   RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxx
RESEND_API_KEY=
#
# Force a specific provider when both are set. Defaults to 'auto'
# (prefers Resend). Set to 'smtp' or 'resend' to pin.
# EMAIL_PROVIDER=auto|smtp|resend
EMAIL_PROVIDER=

MERGECREW_EMAIL_FROM=noreply@mergecrew.dev

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
LOG_LEVEL=info

# --- KMS (encryption) ---
KMS_MASTER_KEY=base64:0000000000000000000000000000000000000000000=  # 32-byte base64 key for dev only

# --- Agent transcript store (#4) ---
# Pick ONE. Both unset = transcripts not persisted (steps still run; the
# transcript_url column on agent_steps stays NULL).
#
# S3 (works against AWS, MinIO, LocalStack via S3_ENDPOINT_URL):
# TRANSCRIPT_S3_BUCKET=mergecrew-transcripts
# S3_ENDPOINT_URL=http://localhost:9000  # only when using MinIO/LocalStack
#
# Filesystem fallback (good enough for dev / single-box installs):
# TRANSCRIPT_LOCAL_DIR=/var/lib/mergecrew/transcripts

# --- Host port bindings (docker-compose.prod.yml) ---
# Containers always listen on 3000 (web) / 4000 (api) internally. These
# vars only control the host-side port the reverse proxy talks to.
# Override when those ports are already taken on the host.
# WEB_HOST_PORT=3000
# API_HOST_PORT=4000

# --- Per-service container resource limits (#187) ---
# Honored by `docker-compose.prod.yml` as cgroup hard caps. Defaults
# assume a 4-vCPU / 8 GB single-VM deploy. The runner is the most
# important to cap — it executes user-derived agent workloads (build
# tools, test runners, file edits) that can spawn unbounded child
# processes. Translate the same numbers to k8s `resources.limits` or
# ECS task-definition cpu/memory for those topologies.
#
# RUNNER_CPU_LIMIT=1
# RUNNER_MEM_LIMIT=1g
# API_CPU_LIMIT=1
# API_MEM_LIMIT=1g
# ORCHESTRATOR_CPU_LIMIT=0.5
# ORCHESTRATOR_MEM_LIMIT=512m
# WORKER_CRON_CPU_LIMIT=0.25
# WORKER_CRON_MEM_LIMIT=256m
# WEB_CPU_LIMIT=0.5
# WEB_MEM_LIMIT=512m
