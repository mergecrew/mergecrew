{
  "name": "@mergecrew/eval-runner",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "mergecrew-eval": "dist/main.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "run": "tsx src/main.ts",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@langchain/core": "^1.1.45",
    "@mergecrew/db": "workspace:*",
    "@mergecrew/eval-fixtures": "workspace:*",
    "@mergecrew/llm": "workspace:*",
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
