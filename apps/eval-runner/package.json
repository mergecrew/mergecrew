{
  "name": "@mergecrew/eval-runner",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main.js",
  "bin": {
    "mergecrew-eval": "dist/main.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/main.ts",
    "run": "tsx src/main.ts",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@mergecrew/db": "workspace:*",
    "@mergecrew/eval-fixtures": "workspace:*",
    "@mergecrew/llm": "workspace:*",
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
